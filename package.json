{
  "name": "personal-ai-tools",
  "version": "0.1.0",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "scripts": {
    "tsc": "tsc --noEmit",
    "lint": "biome lint pi-extensions skills && eslint pi-extensions",
    "lint:biome": "biome lint pi-extensions skills",
    "lint:eslint": "eslint pi-extensions",
    "format": "biome check --write pi-extensions skills",
    "check": "bun run tsc && bun run lint"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@eslint/js": "^10.0.1",
    "@mariozechner/pi-ai": "^0.72.1",
    "@mariozechner/pi-coding-agent": "^0.72.1",
    "@mariozechner/pi-tui": "^0.72.1",
    "@types/js-yaml": "^4.0.9",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "pi": {
    "extensions": [
      "./pi-extensions/ask/index.ts",
      "./pi-extensions/indicators.ts",
      "./pi-extensions/model-context/index.ts",
      "./pi-extensions/notify.ts",
      "./pi-extensions/plan/index.ts",
      "./pi-extensions/review/index.ts",
      "./pi-extensions/telegram/index.ts",
      "./pi-extensions/search/index.ts",
      "./pi-extensions/compact/index.ts",
      "./pi-extensions/check.ts",
      "./pi-extensions/chains/index.ts",
      "./pi-extensions/auto-update/index.ts",
      "./pi-extensions/codex-swap/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
